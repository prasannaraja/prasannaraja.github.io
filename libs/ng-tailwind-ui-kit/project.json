{
    "name": "ng-tailwind-ui-kit",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "libs/ng-tailwind-ui-kit/src",
    "prefix": "prasannaraja.github.io",
    "tags": [],
    "projectType": "library",
    "targets": {
        "build": {
            "executor": "@nx/angular:package",
            "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
            "options": {
                "project": "libs/ng-tailwind-ui-kit/ng-package.json"
            },
            "configurations": {
                "production": {
                    "tsConfig": "libs/ng-tailwind-ui-kit/tsconfig.lib.prod.json"
                },
                "development": {
                    "tsConfig": "libs/ng-tailwind-ui-kit/tsconfig.lib.json"
                }
            },
            "defaultConfiguration": "production"
        },
        "test": {
            "executor": "@nx/jest:jest",
            "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
            "options": {
                "jestConfig": "libs/ng-tailwind-ui-kit/jest.config.ts",
                "passWithNoTests": true
            },
            "configurations": {
                "ci": {
                    "ci": true,
                    "codeCoverage": true
                }
            }
        },
        "lint": {
            "executor": "@nx/linter:eslint",
            "outputs": ["{options.outputFile}"],
            "options": {
                "lintFilePatterns": [
                    "libs/ng-tailwind-ui-kit/**/*.ts",
                    "libs/ng-tailwind-ui-kit/**/*.html"
                ]
            }
        }
    }
}
