{
    "name": "portfolio-src-app-home",
    "$schema": "../../../../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "apps/portfolio/src/app/home/src",
    "prefix": "prasannaraja.github.io",
    "tags": [],
    "projectType": "library",
    "targets": {
        "test": {
            "executor": "@nx/jest:jest",
            "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
            "options": {
                "jestConfig": "apps/portfolio/src/app/home/jest.config.ts",
                "passWithNoTests": true
            },
            "configurations": {
                "ci": {
                    "ci": true,
                    "codeCoverage": true
                }
            }
        },
        "lint": {
            "executor": "@nx/linter:eslint",
            "outputs": ["{options.outputFile}"],
            "options": {
                "lintFilePatterns": [
                    "apps/portfolio/src/app/home/**/*.ts",
                    "apps/portfolio/src/app/home/**/*.html"
                ]
            }
        }
    }
}
